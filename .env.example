# Salin file ini jadi ".env" lalu isi dengan kredensial database.
# JANGAN commit file ".env" ke Git — sudah masuk .gitignore.
#
# Untuk development lokal, API backend harus dijalankan terpisah:
#   cd api && npm install && npm run dev

# Database PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=keuangan
DB_USER=keuangan_app
DB_PASSWORD=isi-password-database

# JWT Secret
JWT_SECRET=isi-jwt-secret

# API Port
API_PORT=3001
