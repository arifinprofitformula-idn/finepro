# Salin file ini jadi ".env" lalu isi dengan kredensial database.
# JANGAN commit file ".env" ke Git — sudah masuk .gitignore.
#
# Untuk development lokal, API backend harus dijalankan terpisah:
#   cd api && npm install && npm run dev

# Database PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=keuangan
DB_USER=keuangan_app
DB_PASSWORD=isi-password-database

# JWT Secret
JWT_SECRET=isi-jwt-secret

# API Port
API_PORT=3001
# Base URL API untuk frontend. Biarkan /api jika frontend dan backend
# dipublish di domain yang sama lewat Nginx proxy.
VITE_API_BASE_URL=/api

# Admin bootstrap
# Isi email user yang boleh masuk Admin Console walaupun role DB belum diset.
# Pisahkan dengan koma jika lebih dari satu.
ADMIN_EMAILS=admin@finepro.my.id
ADMIN_SUPER_EMAILS=owner@finepro.my.id

# Integrasi pihak ketiga dapat dikelola dari Admin Console.
# Nilai .env di bawah menjadi fallback awal sebelum disimpan ke database.
MAILKETING_API_TOKEN=isi-api-token-mailketing
MAILKETING_FROM_EMAIL=isi-email-pengirim-terverifikasi
MAILKETING_FROM_NAME=Finepro

MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=isi-server-key-midtrans
MIDTRANS_CLIENT_KEY=isi-client-key-midtrans

VAPID_PUBLIC_KEY=isi-vapid-public-key
VAPID_PRIVATE_KEY=isi-vapid-private-key
VAPID_SUBJECT=mailto:admin@finepro.my.id

# URL publik app (dipakai untuk tautan reset password di email, dan redirect Midtrans).
# Wajib di production agar email reset mengarah ke domain publik yang benar.
APP_BASE_URL=

# Login/Signup via Google — OAuth Client ID (tipe "Web application") dari
# Google Cloud Console > APIs & Services > Credentials. Tidak perlu Client Secret.
# Isi GOOGLE_CLIENT_ID (backend) dan VITE_GOOGLE_CLIENT_ID (frontend) dengan nilai yang sama.
GOOGLE_CLIENT_ID=isi-google-client-id
VITE_GOOGLE_CLIENT_ID=isi-google-client-id

AI_PROVIDER=sumopod
SUMOPOD_API_KEY=isi-sumopod-api-key
SUMOPOD_BASE_URL=https://ai.sumopod.com/v1
SUMOPOD_MODEL=gpt-4o-mini

# Alternatif jika ingin memakai Anthropic dari Admin Console.
ANTHROPIC_API_KEY=isi-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-5
AI_INSIGHTS_DAILY_LIMIT=3
RECEIPT_SCAN_MONTHLY_LIMIT=30

# Scan struk — OCR lokal (Tesseract, harus terinstal di VPS) + parsing teks
# lewat LLM murah. Lihat api/services/receiptExtraction.js.
TESSERACT_LANG=ind+eng
RECEIPT_PARSE_PROVIDER=sumopod
SUMOPOD_RECEIPT_MODEL=gpt-4o-mini
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5
# Opsional — hanya perlu diisi kalau binary/tessdata tesseract tidak ada di
# lokasi default sistem (mis. dev Windows tanpa akses tulis ke Program Files).
# Kosongkan di VPS Ubuntu yang sudah `apt install tesseract-ocr tesseract-ocr-ind`.
# TESSERACT_BINARY_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
# TESSDATA_DIR=C:\path\to\project\api\tessdata

# Integrasi Telegram (bot BotFather + workflow n8n) — dapat juga dikelola
# dari Admin Console (menu Integrasi > Telegram). Nilai di bawah jadi
# fallback awal sebelum disimpan ke database.
# TELEGRAM_BOT_TOKEN=isi-token-dari-botfather
# TELEGRAM_BOT_USERNAME=isi-username-bot-tanpa-@
# TELEGRAM_N8N_SECRET=isi-secret-acak-untuk-header-X-N8N-Secret
